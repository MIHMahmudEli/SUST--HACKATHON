# Copy to .env and fill in real values. Never commit the real .env.
# Groq API key (free tier). Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Groq model id. Fast + high free-tier limits: llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant
# Set to "false" to run fully rule-based (no LLM calls). Service is safe either way.
USE_LLM=true
# Hard timeout for the LLM polish call (ms). Falls back to rule-based draft on timeout.
LLM_TIMEOUT_MS=8000
# Port the service binds (0.0.0.0). Hosts like Render inject PORT automatically.
PORT=8000
